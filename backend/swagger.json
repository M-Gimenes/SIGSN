    "/relatorios/agendamentos": {
      "get": {
        "tags": [
          "Relatórios"
        ],
        "summary": "RF39 — Listar Agendamentos",
        "description": "Lista agendamentos com filtros opcionais e agregações COUNT(*) + SUM(visitantes, valor).",
        "parameters": [
          {
            "name": "dataInicial",
            "in": "query",
            "description": "Data inicial (YYYY-MM-DD).",
            "schema": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "example": "string"
                },
                "example": {
                  "type": "string",
                  "example": "2026-04-01"
                }
              }
            }
          },
          {
            "name": "dataFinal",
            "in": "query",
            "description": "Data final (YYYY-MM-DD).",
            "schema": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "example": "string"
                },
                "example": {
                  "type": "string",
                  "example": "2026-04-30"
                }
              }
            }
          },
          {
            "name": "tipoVisita",
