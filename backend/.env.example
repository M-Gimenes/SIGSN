# ─── Conexão com o banco ────────────────────────────────────────────────────
#
# Opção A: string de conexão única (formato usado pelo Render).
# DATABASE_URL=postgres://usuario:senha@host:5432/nome_do_banco
#
# Opção B: variáveis separadas (útil para Postgres local).
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=sigsn
# PGSSL=false
#
# Se nenhuma variável for definida, a aplicação cai para SQLite
# (arquivo database.sqlite criado em backend/).
